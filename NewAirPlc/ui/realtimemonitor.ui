}
QPushButton:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
        stop:0 #2563eb, 
        stop:1 #1e40af);
    transform: translateY(-1px);
}
QPushButton:pressed {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
        stop:0 #1e40af, 
        stop:1 #1e3a8a);
    transform: translateY(1px);
}
