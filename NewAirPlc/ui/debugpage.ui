  <property name="styleSheet">
   <string notr="true">
/* ========== 全局样式 - 现代化设计 ========== */
QWidget#DebugPage {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
        stop:0 #e8f0f7, 
        stop:0.5 #f5f8fc, 
        stop:1 #e8f0f7);
    border: none;
}

QWidget#scrollAreaWidgetContents {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
        stop:0 #e8f0f7, 
        stop:0.5 #f5f8fc, 
        stop:1 #e8f0f7);
    border: none;
}

QScrollBar:vertical {
    border: none;
    background: #e2e8f0;
    width: 14px;
    border-radius: 7px;
    margin: 0;
}

QScrollBar::handle:vertical {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #94a3b8,
        stop:1 #64748b);
    border-radius: 7px;
    min-height: 50px;
}

QScrollBar::handle:vertical:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #64748b,
        stop:1 #475569);
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    border: none;
    background: none;
    height: 0px;
}

QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical {
    background: none;
}

QPushButton {
    background-color: #dbeafe;
    color: #1e40af;
    border: 2px solid #93c5fd;
    border-radius: 8px;
    padding: 10px 16px;
    font-family: &quot;Microsoft YaHei&quot;, &quot;SimHei&quot;;
    font-size: 14px;
    font-weight: 600;
}

QPushButton:hover {
    background-color: #bfdbfe;
    border: 2px solid #60a5fa;
    color: #1e3a8a;
}

QPushButton:pressed {
    background-color: #93c5fd;
    border: 2px solid #3b82f6;
    color: #1e3a8a;
}

QPushButton:disabled {
    background-color: #f1f5f9;
    border: 2px solid #e2e8f0;
    color: #94a3b8;
}

QPushButton:checked {
    background-color: #d1fae5;
    border: 2px solid #34d399;
    color: #065f46;
    font-weight: 700;
}

QPushButton#okBtn {
    background-color: #d1fae5;
    border: 2px solid #6ee7b7;
    color: #065f46;
    font-weight: 700;
}

QPushButton#tdBtn {
    background-color: #fef3c7;
    border: 2px solid #fcd34d;
    color: #92400e;
    font-weight: 700;
}

QPushButton#rdBtn {
    background-color: #dbeafe;
    border: 2px solid #93c5fd;
    color: #1e40af;
    font-weight: 700;
}

QPushButton#alBtn {
    background-color: #fee2e2;
    border: 2px solid #fca5a5;
    color: #991b1b;
    font-weight: 700;
}

QPushButton#runBtn {
    background-color: #d1fae5;
    border: 2px solid #6ee7b7;
    color: #065f46;
    font-size: 16px;
    font-weight: 800;
    padding: 12px 20px;
}

QPushButton#instrumentStartBtn, QPushButton#instrumentResetBtn {
    background-color: #e0e7ff;
    border: 2px solid #a5b4fc;
    color: #3730a3;
    font-weight: 700;
}

QLabel {
    font-family: &quot;Microsoft YaHei&quot;, &quot;SimHei&quot;;
    font-size: 14px;
    color: #334155;
    font-weight: 500;
}

QLabel#titleLabel {
    color: #1e293b;
    font-size: 28px;
    font-weight: 800;
    letter-spacing: 2px;
}

QLabel#plcStatusLabel, QLabel#ateqStatusLabel {
    color: #ffffff;
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
        stop:0 rgba(16, 185, 129, 0.9), 
        stop:1 rgba(5, 150, 105, 0.9));
    border-radius: 10px;
    padding: 8px 16px;
    font-size: 13px;
    font-weight: 700;
    border: 2px solid rgba(255, 255, 255, 0.3);
}

QLabel#timeLabel {
    color: #64748b;
    font-size: 16px;
    font-weight: 500;
}

QLineEdit {
    background-color: #ffffff;
    border: 2px solid #cbd5e1;
    border-radius: 10px;
    padding: 10px 14px;
    font-family: &quot;Microsoft YaHei&quot;, &quot;SimHei&quot;;
    font-size: 14px;
    color: #1e293b;
    font-weight: 500;
}

QLineEdit:focus {
    border-color: #3b82f6;
    background-color: #ffffff;
}

QGroupBox {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1, 
        stop:0 #ffffff, 
        stop:1 #f8fafc);
    border: 2px solid #cbd5e1;
    border-radius: 14px;
    margin-top: 24px;
    padding: 20px 20px 20px 20px;
    font-family: &quot;Microsoft YaHei&quot;, &quot;SimHei&quot;;
    font-size: 16px;
    font-weight: 700;
    color: #1e293b;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 4px 12px;
    margin-left: 12px;
    color: #3b82f6;
    background-color: white;
    border-radius: 8px;
    border: 2px solid #cbd5e1;
    font-size: 15px;
}
