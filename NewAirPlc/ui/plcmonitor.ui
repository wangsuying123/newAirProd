  <property name="styleSheet">
   <string notr="true">
    /* ========== 主窗口基础样式 ========== */
    QWidget {
     background-color: #ecf0f1;
     font-family: 'Microsoft YaHei', 'SimHei', sans-serif;
     color: #2c3e50;
     font-size: 15px;
    }

    /* ========== 分组框卡片样式 ========== */
    QGroupBox {
     background-color: #ffffff;
     border: 1px solid #d5d8dc;
     border-radius: 8px;
     margin-top: 18px;
     padding: 22px 18px 18px 18px;
     font-weight: 600;
    }

    QGroupBox::title {
     subcontrol-origin: margin;
     subcontrol-position: top left;
     left: 18px;
     top: 8px;
     padding: 4px 10px;
     color: #2c3e50;
     font-weight: bold;
     font-size: 15px;
     background-color: #3498db;
     color: white;
     border-radius: 4px;
    }

    /* ========== 标签统一样式 ========== */
    QLabel {
     color: #5d6d7e;
     font-size: 14px;
     font-weight: 500;
    }

    /* ========== 按钮样式 ========== */
    QPushButton {
     background-color: #3498db;
     color: white;
     border: none;
     border-radius: 6px;
     padding: 10px 18px;
     font-weight: 600;
     font-size: 14px;
     min-width: 80px;
    }

    QPushButton:hover {
     background-color: #2980b9;
    }

    QPushButton:pressed {
     background-color: #21618c;
    }

    QPushButton:disabled {
     background-color: #bdc3c7;
     color: #ecf0f1;
    }

    /* ========== 输入框基础样式 ========== */
    QLineEdit {
     background-color: #ffffff;
     border: 1px solid #d5d8dc;
     border-radius: 6px;
     padding: 8px 12px;
     min-width: 150px;
     font-size: 14px;
     color: #2c3e50;
    }

    QLineEdit:focus {
     border-color: #3498db;
     background-color: #ffffff;
     outline: none;
    }

    QLineEdit:read-only {
     background-color: #f8f9fa;
    }

    /* ========== 下拉框下拉列表样式 ========== */
    QComboBox QAbstractItemView {
     background-color: #ffffff;
     border: 2px solid #cbd5e1;
     border-radius: 12px;
     selection-background-color: #3b82f6;
     selection-color: #ffffff;
     color: #1e293b;
     padding: 6px;
     outline: none;
    }

    QComboBox QAbstractItemView::item {
     min-height: 30px;
     padding: 8px 12px;
     border-radius: 8px;
     margin: 2px 4px;
    }

    QComboBox QAbstractItemView::item:selected {
     background-color: #3b82f6;
     color: #ffffff;
    }

    QComboBox QAbstractItemView::item:hover {
     background-color: #60a5fa;
     color: #ffffff;
    }
   </string>
  </property>
