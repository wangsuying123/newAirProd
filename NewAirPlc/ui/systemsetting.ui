  <property name="styleSheet">
   <string notr="true">
/* ========== 全局样式 ========== */
QWidget {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:1, 
        stop:0 #4facfe, 
        stop:0.5 #00f2fe,
        stop:1 #43e97b);
    font-family: 'Microsoft YaHei', 'SimHei', sans-serif;
    color: #1e293b;
    font-size: 14px;
}

/* ========== 分组框样式 ========== */
QGroupBox {
    background-color: rgba(255, 255, 255, 0.95);
    border: 2px solid #bfdbfe;
    border-radius: 12px;
    margin-top: 16px;
    padding: 18px 15px 15px 15px;
    font-weight: 600;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 15px;
    top: 6px;
    padding: 5px 12px;
    color: white;
    font-weight: 700;
    font-size: 14px;
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #3b82f6,
        stop:1 #60a5fa);
    border-radius: 6px;
}

/* ========== 标签样式 ========== */
QLabel {
    color: #475569;
    font-size: 14px;
    font-weight: 500;
    background: transparent;
}

/* ========== 按钮样式 ========== */
QPushButton {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #dbeafe,
        stop:1 #bfdbfe);
    color: #1e40af;
    border: 2px solid #93c5fd;
    border-radius: 8px;
    padding: 8px 16px;
    font-weight: 700;
    font-size: 14px;
    min-width: 90px;
    min-height: 38px;
}

QPushButton:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #bfdbfe,
        stop:1 #93c5fd);
    border: 2px solid #60a5fa;
    color: #1e3a8a;
}

QPushButton:pressed {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #60a5fa,
        stop:1 #3b82f6);
    border: 2px solid #2563eb;
    color: white;
}

QPushButton:disabled {
    background-color: #f1f5f9;
    border: 2px solid #e2e8f0;
    color: #94a3b8;
}

/* ========== 重置按钮 ========== */
QPushButton#resetButton {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #fef3c7,
        stop:1 #fde68a);
    border: 2px solid #fcd34d;
    color: #92400e;
}

QPushButton#resetButton:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #fde68a,
        stop:1 #fcd34d);
    border: 2px solid #fbbf24;
    color: #78350f;
}

QPushButton#resetButton:pressed {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #fbbf24,
        stop:1 #f59e0b);
    border: 2px solid #d97706;
    color: white;
}

/* ========== 保存按钮 ========== */
QPushButton#saveButton {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #34d399,
        stop:1 #10b981);
    border: none;
    color: white;
    min-width: 120px;
}

QPushButton#saveButton:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #10b981,
        stop:1 #059669);
}

QPushButton#saveButton:pressed {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #059669,
        stop:1 #047857);
}

/* ========== 应用按钮 ========== */
QPushButton#applyButton {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #dbeafe,
        stop:1 #bfdbfe);
    border: 2px solid #93c5fd;
    color: #1e40af;
}

/* ========== 输入框样式 ========== */
QLineEdit {
    background-color: #ffffff;
    border: 2px solid #cbd5e1;
    border-radius: 8px;
    padding: 8px 12px;
    font-size: 14px;
    color: #1e293b;
    min-height: 32px;
}

QLineEdit:focus {
    border-color: #3b82f6;
    background-color: #ffffff;
    outline: none;
}

QLineEdit:read-only {
    background-color: #f8fafc;
    color: #64748b;
}

/* ========== 下拉框样式 ========== */
QComboBox {
    background-color: #ffffff;
    border: 2px solid #cbd5e1;
    border-radius: 8px;
    padding: 8px 12px;
    font-size: 14px;
    color: #1e293b;
    min-height: 32px;
}

QComboBox:hover {
    border-color: #60a5fa;
}

QComboBox:focus {
    border-color: #3b82f6;
}

QComboBox::drop-down {
    border: none;
    width: 30px;
}

QComboBox::down-arrow {
    image: none;
    border-left: 5px solid transparent;
    border-right: 5px solid transparent;
    border-top: 6px solid #64748b;
    margin-right: 8px;
}

QComboBox::down-arrow:hover {
    border-top-color: #3b82f6;
}

QComboBox QAbstractItemView {
    background-color: #ffffff;
    border: 2px solid #bfdbfe;
    border-radius: 10px;
    selection-background-color: #3b82f6;
    selection-color: #ffffff;
    color: #1e293b;
    padding: 4px;
    outline: none;
}

QComboBox QAbstractItemView::item {
    min-height: 28px;
    padding: 6px 10px;
    border-radius: 6px;
    margin: 2px 3px;
}

QComboBox QAbstractItemView::item:selected {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #3b82f6,
        stop:1 #60a5fa);
    color: #ffffff;
}

QComboBox QAbstractItemView::item:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #60a5fa,
        stop:1 #93c5fd);
    color: #1e293b;
}

/* ========== 数字输入框样式 ========== */
QSpinBox {
    background-color: #ffffff;
    border: 2px solid #cbd5e1;
    border-radius: 8px;
    padding: 8px 12px;
    font-size: 14px;
    color: #1e293b;
    min-height: 32px;
}

QSpinBox:focus {
    border-color: #3b82f6;
}

QSpinBox::up-button, QSpinBox::down-button {
    background-color: #f1f5f9;
    border: none;
    width: 20px;
    border-radius: 4px;
}

QSpinBox::up-button:hover, QSpinBox::down-button:hover {
    background-color: #e2e8f0;
}

QSpinBox::up-arrow {
    image: none;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-bottom: 5px solid #64748b;
}

QSpinBox::down-arrow {
    image: none;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 5px solid #64748b;
}

/* ========== 复选框样式 ========== */
QCheckBox {
    spacing: 8px;
    color: #1e293b;
    font-size: 14px;
    font-weight: 500;
    background: transparent;
}

QCheckBox::indicator {
    width: 20px;
    height: 20px;
    border-radius: 5px;
    border: 2px solid #cbd5e1;
    background-color: #ffffff;
}

QCheckBox::indicator:hover {
    border-color: #60a5fa;
}

QCheckBox::indicator:checked {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #3b82f6,
        stop:1 #60a5fa);
    border-color: #3b82f6;
}

QCheckBox::indicator:checked:hover {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
        stop:0 #2563eb,
        stop:1 #3b82f6);
    border-color: #2563eb;
}

/* ========== 滚动区域样式 ========== */
QScrollArea {
    border: none;
    background-color: transparent;
}

QScrollBar:vertical {
    background: rgba(255, 255, 255, 0.3);
    width: 10px;
    border-radius: 5px;
}

QScrollBar::handle:vertical {
    background: rgba(59, 130, 246, 0.7);
    border-radius: 5px;
    min-height: 30px;
}

QScrollBar::handle:vertical:hover {
    background: rgba(37, 99, 235, 0.9);
}

QScrollBar::add-line:vertical, 
QScrollBar::sub-line:vertical {
    height: 0px;
}
